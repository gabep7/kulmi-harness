{
  "name": "kulmi-harness",
  "version": "1.0.1",
  "description": "autonomous coding harness",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabep7/kulmi-harness.git"
  },
  "type": "module",
  "bin": {
    "kulmi": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && chmod +x dist/cli.js && node scripts/source-fingerprint.mjs --write",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "tsx scripts/provider-smoke.ts",
    "test:tui": "vitest run test/tui.test.tsx",
    "test:package": "node scripts/package-smoke.mjs",
    "eval": "node evals/run.mjs",
    "check:version": "node scripts/check-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "node scripts/check.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "playwright-core": "^1.61.1",
    "react": "^19.2.7",
    "ripgrep": "^0.3.1",
    "shell-quote": "^1.8.4",
    "smol-toml": "^1.6.1",
    "typescript-language-server": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.17",
    "@types/shell-quote": "^1.7.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
